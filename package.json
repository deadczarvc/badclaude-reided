{
  "name": "badclaude",
  "version": "1.0.2",
  "description": "Whip Claude into shape",
  "license": "MIT",
  "main": "main.js",
  "bin": {
    "badclaude": "bin/badclaude.js"
  },
  "os": [
    "darwin",
    "win32"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "electron",
    "tray",
    "overlay",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GitFrog1111/badclaude.git"
  },
  "bugs": {
    "url": "https://github.com/GitFrog1111/badclaude/issues"
  },
  "homepage": "https://github.com/GitFrog1111/badclaude#readme",
  "files": [
    "main.js",
    "preload.js",
    "overlay.html",
    "sounds",
    "icon",
    "bin/badclaude.js",
    "README.md"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "npm pack",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "electron": "^42.0.0",
    "koffi": "^2.9.0"
  },
  "build": {
    "appId": "com.yourname.badclaude",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron-builder": "^26.8.1"
  }
}
